{
  "name": "model-council",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/chat",
    "packages/protocol"
  ],
  "scripts": {
    "dev": "next dev examples/next",
    "build": "next build examples/next",
    "build:protocol": "npm run build -w @your-scope/protocol",
    "build:chat": "npm run build -w @your-scope/protocol && npm run build -w @your-scope/chat",
    "start": "next start examples/next",
    "lint": "eslint",
    "prisma:generate": "prisma generate --schema examples/next/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema examples/next/prisma/schema.prisma"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.44",
    "@ai-sdk/google": "^3.0.29",
    "@ai-sdk/openai": "^3.0.29",
    "@ai-sdk/react": "^3.0.88",
    "@electric-sql/pglite": "^0.4.5",
    "@prisma/client": "6.19.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.11.0",
    "next": "16.1.6",
    "ollama-ai-provider-v2": "^3.5.0",
    "postcss": "^8.5.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.1",
    "tsup": "^8.5.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "6.19.3",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
